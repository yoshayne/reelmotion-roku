<?xml version="1.0" encoding="utf-8" ?>
<component name="ActivationScreen" extends="Group">
  <interface>
    <field id="close" type="boolean" alwaysNotify="true" />
    <field id="goHome" type="boolean" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/screens/ActivationScreen.brs" />
  <children>
    <!-- Black background -->
    <Rectangle id="bg" color="#000000" width="1280" height="720" />
    <!-- Logo centered top area -->
    <Poster id="logo" uri="pkg:/images/logo.png" width="280" height="80" translation="[500, 180]" />
    <!-- Activation code - large red -->
    <Label id="codeLabel" text="" color="#DC2626" font="font:LargeBoldSystemFont" horizAlign="center" width="1280" translation="[0, 320]" />
    <!-- Instructions -->
    <Label id="instrLabel" text="Go to reelmotionapp.com/activate on your phone or computer and enter this code" color="#FFFFFF" font="font:SmallSystemFont" horizAlign="center" width="900" translation="[190, 400]" wrap="true" />
    <!-- Loading spinner -->
    <BusySpinner id="spinner" translation="[610, 470]" visible="true" />
    <!-- Error state -->
    <Label id="errorLabel" text="" color="#DC2626" font="font:SmallSystemFont" horizAlign="center" width="1280" translation="[0, 500]" visible="false" />
    <Button id="retryButton" text="Get New Code" translation="[490, 540]" visible="false" />
  </children>
</component>
