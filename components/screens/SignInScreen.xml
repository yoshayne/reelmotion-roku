<?xml version="1.0" encoding="utf-8" ?>
<component name="SignInScreen" extends="Group">
  <interface>
    <field id="signInComplete" type="boolean" alwaysNotify="true" />
    <field id="sessionToken" type="string" />
    <field id="useActivationCode" type="boolean" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/screens/SignInScreen.brs" />
  <children>
    <Rectangle id="bg" color="#000000" width="1280" height="720" />

    <!-- Logo -->
    <Poster id="logo" uri="pkg:/images/logo.png" width="280" height="80" translation="[500, 100]" />

    <!-- Headline -->
    <Label id="headlineLabel" text="Sign in to ReelMotion" color="#FFFFFF" font="font:MediumBoldSystemFont" horizAlign="center" width="1280" translation="[0, 210]" />

    <!-- Email label + input -->
    <Label id="emailLabel" text="Email" color="#9CA3AF" font="font:SmallSystemFont" translation="[440, 290]" />
    <Rectangle id="emailBorder" color="#374151" width="400" height="52" translation="[440, 310]" />
    <Rectangle id="emailFocusBorder" color="#DC2626" width="400" height="52" translation="[440, 310]" visible="false" />
    <EditText id="emailField" width="388" height="40" translation="[446, 316]" hintText="you@example.com" hintTextColor="#6B7280" />

    <!-- Password label + input -->
    <Label id="passwordLabel" text="Password" color="#9CA3AF" font="font:SmallSystemFont" translation="[440, 378]" />
    <Rectangle id="passwordBorder" color="#374151" width="400" height="52" translation="[440, 398]" />
    <Rectangle id="passwordFocusBorder" color="#DC2626" width="400" height="52" translation="[440, 398]" visible="false" />
    <EditText id="passwordField" width="388" height="40" translation="[446, 404]" hintText="Password" hintTextColor="#6B7280" secureMode="true" />

    <!-- Sign In button -->
    <Rectangle id="signInBtnBg" color="#DC2626" width="400" height="52" translation="[440, 476]" />
    <Label id="signInBtnLabel" text="Sign In" color="#FFFFFF" font="font:MediumBoldSystemFont" horizAlign="center" width="400" translation="[440, 490]" />

    <!-- Sign Up hint -->
    <Label id="signUpLabel" text="New member? Join at reelmotionapp.com" color="#9CA3AF" font="font:SmallSystemFont" horizAlign="center" width="1280" translation="[0, 550]" />

    <!-- Activation code toggle -->
    <Label id="activationCodeLabel" text="Use activation code instead" color="#9CA3AF" font="font:SmallSystemFont" horizAlign="center" width="1280" translation="[0, 630]" />

    <!-- Spinner -->
    <BusySpinner id="spinner" translation="[624, 480]" visible="false" />

    <!-- Error -->
    <Label id="errorLabel" text="" color="#DC2626" font="font:SmallSystemFont" horizAlign="center" width="1000" translation="[140, 600]" visible="false" wrap="true" />
  </children>
</component>
