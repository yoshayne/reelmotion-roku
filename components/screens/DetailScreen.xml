<?xml version="1.0" encoding="utf-8" ?>
<component name="DetailScreen" extends="Group">
  <interface>
    <field id="close" type="boolean" alwaysNotify="true" />
    <field id="playRequested" type="boolean" alwaysNotify="true" />
    <field id="videoData" type="assocarray" alwaysNotify="true" />
    <field id="authToken" type="string" />
    <field id="subscriptionActive" type="boolean" />
    <field id="contentId" type="string" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/screens/DetailScreen.brs" />
  <children>
    <!-- Hero background -->
    <Poster id="heroPoster" width="1280" height="720" />
    <Rectangle id="heroOverlay" color="#000000" opacity="0.7" width="1280" height="720" />
    <!-- Content -->
    <Label id="titleLabel" color="#FFFFFF" font="font:MediumBoldSystemFont" translation="[80, 200]" width="700" />
    <Label id="metaLabel" color="#9CA3AF" font="font:SmallestSystemFont" translation="[80, 270]" width="700" />
    <Label id="descLabel" color="#FFFFFF" font="font:SmallSystemFont" translation="[80, 310]" width="700" height="120" wrap="true" />
    <!-- Buttons -->
    <Button id="playBtn" text="&#x25BA;  Play" translation="[80, 450]" minWidth="160" />
    <Button id="myListBtn" text="&#xFF0B;  My List" translation="[260, 450]" minWidth="160" />
    <Button id="moreInfoBtn" text="&#x24D8;  More Info" translation="[440, 450]" minWidth="160" />
    <!-- Members only label -->
    <Label id="membersLabel" text="Members Only &#x2014; Join at reelmotionapp.com" color="#DC2626" font="font:SmallSystemFont" translation="[80, 450]" visible="false" />
    <!-- Comments section -->
    <Label id="communityLabel" text="Community" color="#FFFFFF" font="font:MediumBoldSystemFont" translation="[80, 530]" />
    <Rectangle id="communityAccent" color="#DC2626" width="100" height="3" translation="[80, 565]" />
    <Label id="commentsLabel" color="#9CA3AF" font="font:SmallestSystemFont" translation="[80, 580]" width="700" height="120" wrap="true" />
    <!-- Loading -->
    <BusySpinner id="spinner" translation="[610, 360]" />
  </children>
</component>
